{
  "name": "lakeql-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "webgpu"
    ]
  },
  "scripts": {
    "build": "tsc -b && pnpm --filter lakeql build && tsc -p fixtures",
    "test": "vitest run",
    "test:workerd": "vitest run -c vitest.workerd.config.ts",
    "test:conformance": "LAKEQL_CONFORMANCE=1 vitest run -c vitest.conformance.config.ts",
    "test:reference": "LAKEQL_REFERENCE=1 vitest run -c vitest.reference.config.ts",
    "test:providers": "vitest run -c vitest.providers.config.ts",
    "coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "node scripts/typecheck.mjs",
    "docs:compatibility": "node scripts/generate-compatibility.mjs",
    "check:compatibility": "node scripts/generate-compatibility.mjs --check",
    "check:large-files": "node scripts/check-large-files.mjs",
    "check:packages": "node scripts/check-package-install.mjs",
    "fixtures": "pnpm --filter lakeql-fixtures generate",
    "fixtures:external": "pnpm --filter lakeql-fixtures fetch:external",
    "fixtures:iceberg": "pnpm --filter lakeql-fixtures generate:iceberg",
    "bench": "pnpm build && node bench/run.mjs",
    "bench:duckdb": "pnpm build && node bench/duckdb-compare.mjs",
    "bench:browser-r2": "pnpm build && node bench/browser-spatial-fixture.mjs && node bench/browser-window-fixture.mjs && pnpm --dir site build",
    "bench:bundle": "pnpm build && node bench/bundle.mjs",
    "bench:lance": "pnpm build && node bench/lance-random-read.mjs",
    "bench:webgpu": "pnpm build && node bench/webgpu.mjs",
    "bench:webgpu-vector": "pnpm build && node bench/webgpu-vector.mjs",
    "bench:workunits": "pnpm build && node bench/workunits.mjs",
    "bench:workunits:10m": "LAKEQL_WORKUNIT_ROWS=10000000 LAKEQL_WORKUNIT_ROWS_PER_FILE=100000 LAKEQL_WORKUNIT_ROW_GROUP_ROWS=10000 LAKEQL_WORKUNIT_ROW_GROUPS_PER_TASK=1 LAKEQL_WORKUNIT_CONCURRENT_TASKS=2 LAKEQL_WORKUNIT_SELECTED_TAIL_ROWS=100000 LAKEQL_WORKUNIT_MAX_FANOUT_RSS_DELTA_MB=256 LAKEQL_WORKUNIT_MAX_FANOUT_BYTES=6291456 LAKEQL_WORKUNIT_MAX_FANOUT_RANGES=32 LAKEQL_WORKUNIT_MAX_PLANNING_BYTES=8388608 LAKEQL_WORKUNIT_MAX_PLANNING_RANGES=100 LAKEQL_WORKUNIT_MAX_ROWS_DECODED=100000 LAKEQL_WORKUNIT_MAX_PLANNED_ROW_GROUPS=10 LAKEQL_WORKUNIT_MAX_WORK_UNITS=10 LAKEQL_WORKUNIT_MAX_ROWS_PER_FANOUT_WAVE=20000 pnpm bench:workunits",
    "bench:workunits:10m:duckdb": "LAKEQL_WORKUNIT_COMPARE_DUCKDB=1 pnpm bench:workunits:10m",
    "bench:workunits:10m:high-cardinality": "LAKEQL_WORKUNIT_BUCKET_CARDINALITY=100000 pnpm bench:workunits:10m",
    "bench:workunits:10m:high-cardinality:duckdb": "LAKEQL_WORKUNIT_COMPARE_DUCKDB=1 pnpm bench:workunits:10m:high-cardinality",
    "perf:hot": "LAKEQL_HOT_PERF=1 vitest run packages/parquet/src/flights-hot-performance.test.ts",
    "perf:hot:profile": "node scripts/profile-hot-performance.mjs",
    "check:changeset": "node scripts/check-changeset.mjs",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm check && changeset publish",
    "check": "pnpm lint && pnpm build && pnpm typecheck && pnpm check:compatibility && pnpm check:large-files && pnpm check:packages && pnpm test && pnpm test:workerd && pnpm test:conformance && pnpm test:reference && pnpm coverage && node scripts/check-fixtures.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.31.0",
    "@cloudflare/vitest-pool-workers": "0.16.15",
    "@duckdb/node-api": "1.5.3-r.3",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "@webgpu/types": "0.1.71",
    "avsc": "^5.7.9",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "webgpu": "0.4.0"
  }
}
